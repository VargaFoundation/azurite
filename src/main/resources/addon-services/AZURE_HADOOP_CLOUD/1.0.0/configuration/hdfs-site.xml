<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration supports_adding_forbidden="false">

  <property>
    <name>dfs.namenode.rpc-address</name>
    <value>localhost:8020</value>
    <display-name>NameNode RPC Address</display-name>
    <description>NameNode RPC address. Used when HDFS is the storage backend or in hybrid mode.</description>
    <depends-on>
      <property>
        <type>azure-cloud-env</type>
        <name>azure_storage_backend</name>
      </property>
    </depends-on>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>dfs.webhdfs.enabled</name>
    <value>true</value>
    <display-name>WebHDFS Enabled</display-name>
    <description>Enable WebHDFS REST API.</description>
    <value-attributes>
      <type>boolean</type>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

</configuration>
