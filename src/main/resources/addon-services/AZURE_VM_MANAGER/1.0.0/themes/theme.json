{
  "name": "default",
  "description": "Default theme for Azure VM Manager service",
  "configuration": {
    "layouts": [
      {
        "name": "default",
        "tabs": [
          {
            "name": "settings",
            "display-name": "VM Settings",
            "layout": {
              "tab-columns": "2",
              "tab-rows": "3",
              "sections": [
                {
                  "name": "section-vm-mode",
                  "display-name": "Management Mode",
                  "row-index": "0", "column-index": "0", "row-span": "1", "column-span": "1",
                  "section-columns": "1", "section-rows": "1",
                  "subsections": [{"name": "subsection-vm-mode", "row-index": "0", "column-index": "0", "row-span": "1", "column-span": "1"}]
                },
                {
                  "name": "section-networking",
                  "display-name": "Networking",
                  "row-index": "0", "column-index": "1", "row-span": "1", "column-span": "1",
                  "section-columns": "1", "section-rows": "3",
                  "subsections": [{"name": "subsection-networking", "row-index": "0", "column-index": "0", "row-span": "3", "column-span": "1"}]
                },
                {
                  "name": "section-worker-pool",
                  "display-name": "Worker Pool",
                  "row-index": "1", "column-index": "0", "row-span": "1", "column-span": "2",
                  "section-columns": "2", "section-rows": "3",
                  "subsections": [{"name": "subsection-worker-pool", "row-index": "0", "column-index": "0", "row-span": "3", "column-span": "2"}]
                }
              ]
            }
          }
        ]
      }
    ],
    "placement": {
      "configs": [
        {"config": "azure-vm-manager-env/vm_manager_mode", "subsection-name": "subsection-vm-mode"},
        {"config": "azure-vm-manager-site/azure.vm.vnet.name", "subsection-name": "subsection-networking"},
        {"config": "azure-vm-manager-site/azure.vm.subnet.name", "subsection-name": "subsection-networking"},
        {"config": "azure-vm-manager-site/azure.vm.ssh.public.key", "subsection-name": "subsection-networking"},
        {"config": "azure-vm-pool-site/azure.vm.pool.worker.size", "subsection-name": "subsection-worker-pool"},
        {"config": "azure-vm-pool-site/azure.vm.pool.worker.min.count", "subsection-name": "subsection-worker-pool"},
        {"config": "azure-vm-pool-site/azure.vm.pool.worker.max.count", "subsection-name": "subsection-worker-pool"},
        {"config": "azure-vm-pool-site/azure.vm.pool.worker.initial.count", "subsection-name": "subsection-worker-pool"},
        {"config": "azure-vm-pool-site/azure.vm.pool.worker.type", "subsection-name": "subsection-worker-pool"},
        {"config": "azure-vm-pool-site/azure.vm.pool.worker.spot.enabled", "subsection-name": "subsection-worker-pool"}
      ]
    },
    "widgets": [
      {"config": "azure-vm-manager-env/vm_manager_mode", "widget": {"type": "combo"}},
      {"config": "azure-vm-pool-site/azure.vm.pool.worker.type", "widget": {"type": "combo"}}
    ]
  }
}
