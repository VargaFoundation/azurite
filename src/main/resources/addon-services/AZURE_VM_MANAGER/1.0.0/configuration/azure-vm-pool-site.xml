<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration supports_adding_forbidden="false">

  <!-- Head Nodes -->
  <property>
    <name>azure.vm.pool.head.size</name>
    <value>Standard_D4_v3</value>
    <display-name>Head Node VM Size</display-name>
    <description>Azure VM size for head (master) nodes.</description>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.head.count</name>
    <value>2</value>
    <display-name>Head Node Count</display-name>
    <description>Number of head nodes (active/standby for HA).</description>
    <value-attributes>
      <type>int</type>
      <minimum>1</minimum>
      <maximum>2</maximum>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.head.disk.type</name>
    <value>Premium_LRS</value>
    <display-name>Head Node Disk Type</display-name>
    <description>Managed disk type for head node OS disk.</description>
    <value-attributes>
      <type>value-list</type>
      <entries>
        <entry><value>Premium_LRS</value><label>Premium SSD</label></entry>
        <entry><value>StandardSSD_LRS</value><label>Standard SSD</label></entry>
        <entry><value>Standard_LRS</value><label>Standard HDD</label></entry>
      </entries>
      <selection_cardinality>1</selection_cardinality>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.head.disk.size.gb</name>
    <value>128</value>
    <display-name>Head Node OS Disk Size (GB)</display-name>
    <value-attributes>
      <type>int</type>
      <minimum>64</minimum>
      <maximum>4096</maximum>
      <unit>GB</unit>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.head.data.disks</name>
    <value>2</value>
    <display-name>Head Node Data Disk Count</display-name>
    <value-attributes>
      <type>int</type>
      <minimum>0</minimum>
      <maximum>32</maximum>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.head.data.disk.size.gb</name>
    <value>256</value>
    <display-name>Head Node Data Disk Size (GB)</display-name>
    <value-attributes>
      <type>int</type>
      <minimum>32</minimum>
      <maximum>4096</maximum>
      <unit>GB</unit>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <!-- Worker Nodes -->
  <property>
    <name>azure.vm.pool.worker.size</name>
    <value>Standard_D4_v3</value>
    <display-name>Worker Node VM Size</display-name>
    <description>Azure VM size for worker nodes. Select from common Hadoop-suitable sizes or enter a custom size.</description>
    <value-attributes>
      <type>value-list</type>
      <entries>
        <entry><value>Standard_D4_v3</value><label>D4 v3 (4 vCPU, 16 GB)</label></entry>
        <entry><value>Standard_D8_v3</value><label>D8 v3 (8 vCPU, 32 GB)</label></entry>
        <entry><value>Standard_D16_v3</value><label>D16 v3 (16 vCPU, 64 GB)</label></entry>
        <entry><value>Standard_D32_v3</value><label>D32 v3 (32 vCPU, 128 GB)</label></entry>
        <entry><value>Standard_D4s_v3</value><label>D4s v3 (4 vCPU, 16 GB, Premium SSD)</label></entry>
        <entry><value>Standard_D8s_v3</value><label>D8s v3 (8 vCPU, 32 GB, Premium SSD)</label></entry>
        <entry><value>Standard_D16s_v3</value><label>D16s v3 (16 vCPU, 64 GB, Premium SSD)</label></entry>
        <entry><value>Standard_E4_v3</value><label>E4 v3 (4 vCPU, 32 GB, Memory-optimized)</label></entry>
        <entry><value>Standard_E8_v3</value><label>E8 v3 (8 vCPU, 64 GB, Memory-optimized)</label></entry>
        <entry><value>Standard_E16_v3</value><label>E16 v3 (16 vCPU, 128 GB, Memory-optimized)</label></entry>
        <entry><value>Standard_F4s_v2</value><label>F4s v2 (4 vCPU, 8 GB, Compute-optimized)</label></entry>
        <entry><value>Standard_F8s_v2</value><label>F8s v2 (8 vCPU, 16 GB, Compute-optimized)</label></entry>
        <entry><value>Standard_L8s_v2</value><label>L8s v2 (8 vCPU, 64 GB, Storage-optimized)</label></entry>
      </entries>
      <selection_cardinality>1</selection_cardinality>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.min.count</name>
    <value>1</value>
    <display-name>Worker Minimum Count</display-name>
    <description>Minimum number of worker nodes (autoscaler floor).</description>
    <value-attributes>
      <type>int</type>
      <minimum>0</minimum>
      <maximum>500</maximum>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.max.count</name>
    <value>20</value>
    <display-name>Worker Maximum Count</display-name>
    <description>Maximum number of worker nodes (autoscaler ceiling).</description>
    <value-attributes>
      <type>int</type>
      <minimum>1</minimum>
      <maximum>500</maximum>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.initial.count</name>
    <value>3</value>
    <display-name>Worker Initial Count</display-name>
    <description>Number of worker nodes to provision at cluster start.</description>
    <value-attributes>
      <type>int</type>
      <minimum>0</minimum>
      <maximum>500</maximum>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.disk.type</name>
    <value>Standard_LRS</value>
    <display-name>Worker Node Disk Type</display-name>
    <value-attributes>
      <type>value-list</type>
      <entries>
        <entry><value>Premium_LRS</value><label>Premium SSD</label></entry>
        <entry><value>StandardSSD_LRS</value><label>Standard SSD</label></entry>
        <entry><value>Standard_LRS</value><label>Standard HDD</label></entry>
      </entries>
      <selection_cardinality>1</selection_cardinality>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.disk.size.gb</name>
    <value>128</value>
    <display-name>Worker Node OS Disk Size (GB)</display-name>
    <value-attributes>
      <type>int</type>
      <minimum>64</minimum>
      <maximum>4096</maximum>
      <unit>GB</unit>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.data.disks</name>
    <value>4</value>
    <display-name>Worker Node Data Disk Count</display-name>
    <value-attributes>
      <type>int</type>
      <minimum>0</minimum>
      <maximum>32</maximum>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.data.disk.size.gb</name>
    <value>512</value>
    <display-name>Worker Node Data Disk Size (GB)</display-name>
    <value-attributes>
      <type>int</type>
      <minimum>32</minimum>
      <maximum>4096</maximum>
      <unit>GB</unit>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.type</name>
    <value>core</value>
    <display-name>Worker Node Type</display-name>
    <description>Worker role: 'core' nodes run persistent storage cache + compute, 'task' nodes run compute only (faster to scale, no local data persistence). When using cloud storage (ADLS Gen2/WASB), both types use cloud storage for data.</description>
    <value-attributes>
      <type>value-list</type>
      <entries>
        <entry><value>core</value><label>Core (Persistent + Compute)</label></entry>
        <entry><value>task</value><label>Task (Compute Only)</label></entry>
      </entries>
      <selection_cardinality>1</selection_cardinality>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.secondary.sizes</name>
    <value></value>
    <display-name>Worker Fallback VM Sizes</display-name>
    <description>Comma-separated list of fallback VM sizes if primary is unavailable (fleet model).</description>
    <value-attributes>
      <empty-value-valid>true</empty-value-valid>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.data.disk.type</name>
    <value>Standard_LRS</value>
    <display-name>Worker Node Data Disk Type</display-name>
    <description>Managed disk type for worker node data disks. Can differ from OS disk type to optimize cost.</description>
    <value-attributes>
      <type>value-list</type>
      <entries>
        <entry><value>Premium_LRS</value><label>Premium SSD</label></entry>
        <entry><value>StandardSSD_LRS</value><label>Standard SSD</label></entry>
        <entry><value>Standard_LRS</value><label>Standard HDD</label></entry>
        <entry><value>UltraSSD_LRS</value><label>Ultra SSD</label></entry>
      </entries>
      <selection_cardinality>1</selection_cardinality>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.accelerated.networking</name>
    <value>true</value>
    <display-name>Worker Accelerated Networking</display-name>
    <description>Enable accelerated networking (SR-IOV) for worker NICs. Lower latency and higher throughput. Requires a supported VM size (most D/E/F series v3+).</description>
    <value-attributes><type>boolean</type></value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.ephemeral.os.disk</name>
    <value>false</value>
    <display-name>Worker Ephemeral OS Disk</display-name>
    <description>Use ephemeral OS disk for workers. Faster boot and lower cost but OS state is lost on deallocation. Best for stateless compute-only (task) workers.</description>
    <value-attributes><type>boolean</type></value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.spot.enabled</name>
    <value>false</value>
    <display-name>Use Spot VMs for Workers</display-name>
    <description>Use Azure Spot VMs for task worker nodes (lower cost, may be evicted).</description>
    <value-attributes>
      <type>boolean</type>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.worker.spot.max.price</name>
    <value>-1</value>
    <display-name>Spot VM Max Price</display-name>
    <description>Maximum price for Spot VMs (-1 = up to on-demand price).</description>
    <value-attributes>
      <type>float</type>
    </value-attributes>
    <depends-on>
      <property>
        <type>azure-vm-pool-site</type>
        <name>azure.vm.pool.worker.spot.enabled</name>
      </property>
    </depends-on>
    <on-ambari-upgrade add="true"/>
  </property>

  <!-- ZooKeeper Nodes -->
  <property>
    <name>azure.vm.pool.zk.size</name>
    <value>Standard_A2_v2</value>
    <display-name>ZooKeeper Node VM Size</display-name>
    <on-ambari-upgrade add="true"/>
  </property>

  <property>
    <name>azure.vm.pool.zk.count</name>
    <value>3</value>
    <display-name>ZooKeeper Node Count</display-name>
    <description>Number of ZooKeeper nodes (must be odd: 3 or 5).</description>
    <value-attributes>
      <type>int</type>
      <minimum>3</minimum>
      <maximum>7</maximum>
    </value-attributes>
    <on-ambari-upgrade add="true"/>
  </property>

</configuration>
