  "contentVersion": "1.0.0.0",
  "parameters": {
    "clusterName": {
      "value": "azurite"
    },
    "adminUsername": {
      "value": "azureadmin"
    },
    "sshPublicKey": {
      "value": "ssh-rsa AAAA...your-public-key-here... user@host"
